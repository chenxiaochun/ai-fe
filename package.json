{
  "name": "ai-fe",
  "version": "0.1.0",
  "description": "面向 AI-native 前端工程工作流的 CLI。",
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "ai-fe": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node dist/cli.js doctor",
    "dev": "tsc -p tsconfig.json && node dist/cli.js",
    "doctor": "tsc -p tsconfig.json && node dist/cli.js doctor",
    "prepublishOnly": "npm run build && npm test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai",
    "cli",
    "frontend",
    "workflow",
    "cursor",
    "agent"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.5.0"
  }
}
